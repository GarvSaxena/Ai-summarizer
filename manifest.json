{
    "manifest_version": 3,
    "name" : "Ai article summarizer",
    "version": "1.0" ,

    "permissions": ["scripting", "activeTab", "storage"],

    "icons": {
        "128": "favicon.png"
    },

    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "128": "favicon.png"
        }
    },
    

    "content_scripts" :[{
        "matches" : ["<all_urls>"],
        "js": ["content.js"]
    }
    ],

    "background":{
        "service_worker" : "background.js"
    },

    "options_page": "option.html",
    "host_permissions": ["<all_urls>"]


}